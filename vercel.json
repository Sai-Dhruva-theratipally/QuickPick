{
  "version": 2,
  "buildCommand": "cd api && npm install && cd ../client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "serverlessFunctionRegion": "iad1",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    }
  ]
}
